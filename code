      <div class="form-group"><label>Roll No</label><input type="text" id="sRollNo" placeholder="101"></div>
      <div class="form-group"><label>Class</label>
        <select id="sClass"><option>10A</option><option>10B</option><option>11A</option><option>11B</option><option>12A</option></select>
