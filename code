    <div class="form-group"><label>Content</label><textarea id="noteBody" placeholder="Write your note here…"></textarea></div>
    <div class="form-group">
      <label>Color Tag</label>
      <select id="noteColor">
        <option value="#3b82f6">Blue</option>
        <option value="#10b981">Green</option>
        <option value="#f59e0b">Yellow</option>
        <option value="#ef4444">Red</option>
        <option value="#8b5cf6">Purple</option>
      </select>
    </div>
    <div class="modal-actions">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('noteModal')">Cancel</button>
      <button class="btn btn-primary btn-sm" onclick="saveNote()">Save Note</button>
    </div>
  </div>
</div>

<div class="modal-overlay" id="viewNoteModal">
  <div class="modal" style="width:560px">
    <h3 id="viewNoteTitle" style="margin-bottom:16px;"></h3>
    <p id="viewNoteBody" style="color:var(--text-dim);line-height:1.7;font-size:0.95rem;white-space:pre-wrap;"></p>
    <p id="viewNoteMeta" style="margin-top:16px;font-size:0.78rem;color:var(--text-muted);"></p>
    <div class="modal-actions">
      <button class="btn btn-secondary btn-sm" onclick="closeModal('viewNoteModal')">Close</button>
    </div>
  </div>
</div>

<script>
// ════════════════════════════════════════════
//  STATE
// ════════════════════════════════════════════
const USERS = {
  admin:   { pass:'admin123',  role:'admin',   name:'Admin User' },
  teacher: { pass:'teach123',  role:'teacher', name:'Mrs. Sharma' },
  student: { pass:'stu123',    role:'student', name:'Ravi Kumar' },
};

let currentUser = null;
let selectedRole = 'admin';
let editingStudentId = null;
let editingNoteId = null;

let students = [
  { id:1, firstName:'Aarav',    lastName:'Mehta',    rollNo:'101', class:'10A', email:'aarav@school.edu',    phone:'9876543210' },
  { id:2, firstName:'Priya',    lastName:'Sharma',   rollNo:'102', class:'10A', email:'priya@school.edu',    phone:'9876543211' },
  { id:3, firstName:'Rohan',    lastName:'Verma',    rollNo:'103', class:'10B', email:'rohan@school.edu',    phone:'9876543212' },
  { id:4, firstName:'Sneha',    lastName:'Patel',    rollNo:'104', class:'11A', email:'sneha@school.edu',    phone:'9876543213' },
  { id:5, firstName:'Vikram',   lastName:'Singh',    rollNo:'105', class:'11B', email:'vikram@school.edu',   phone:'9876543214' },
  { id:6, firstName:'Ananya',   lastName:'Nair',     rollNo:'106', class:'12A', email:'ananya@school.edu',   phone:'9876543215' },
];
let nextStudentId = 7;

// attendance[date][studentId] = { status:'P'|'A', remark:'' }
let attendance = {};

// marks[studentId] = { Math:0, Science:0, English:0, History:0, Computer:0 }
let marks = {};
students.forEach(s => {
  marks[s.id] = { Mathematics: rnd(50,100), Science: rnd(50,100), English: rnd(50,100), History: rnd(50,100), Computer: rnd(50,100) };
});

let notes = [];
let nextNoteId = 1;

function rnd(a,b){ return Math.floor(Math.random()*(b-a+1))+a; }

// ════════════════════════════════════════════
//  AUTH
// ════════════════════════════════════════════
function setRole(r){ selectedRole=r; document.querySelectorAll('.role-btn').forEach((b,i)=>b.classList.toggle('active',['admin','teacher','student'][i]===r)); }

function doLogin(){
  const u=document.getElementById('loginUser').value.trim();
  const p=document.getElementById('loginPass').value;
  if(USERS[u] && USERS[u].pass===p){
    currentUser = { username:u, ...USERS[u] };
    document.getElementById('loginErr').style.display='none';
    document.getElementById('loginScreen').style.display='none';
    document.getElementById('appShell').style.display='block';
    initApp();
  } else {
    document.getElementById('loginErr').style.display='block';
  }
}
document.addEventListener('keydown', e=>{ if(e.key==='Enter') doLogin(); });

function doLogout(){
  currentUser=null;
  document.getElementById('appShell').style.display='none';
  document.getElementById('loginScreen').style.display='flex';
  document.getElementById('loginUser').value='';
  document.getElementById('loginPass').value='';
}

function initApp(){
  document.getElementById('sidebarName').textContent=currentUser.name;
  document.getElementById('sidebarRole').textContent=currentUser.role==='admin'?'Administrator':currentUser.role==='teacher'?'Teacher':'Student';
  document.getElementById('sidebarAvatar').textContent=currentUser.name[0].toUpperCase();
  document.getElementById('topbarRole').textContent=currentUser.role.charAt(0).toUpperCase()+currentUser.role.slice(1);

  // Restrict nav for student
  if(currentUser.role==='student'){
    document.getElementById('navStudents').style.display='none';
    document.getElementById('navAdminSection').style.display='none';
  }

  // Set today's date on attendance
  const today=new Date().toISOString().split('T')[0];
  document.getElementById('attDate').value=today;
  document.getElementById('topbarDate').textContent=new Date().toLocaleDateString('en-IN',{weekday:'short',day:'numeric',month:'short',year:'numeric'});

  navigate('dashboard');
}

// ════════════════════════════════════════════
//  NAVIGATION
// ════════════════════════════════════════════
function navigate(page){
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  const navMap={dashboard:0,students:1,attendance:2,marks:3,notes:4};
  const items=document.querySelectorAll('.nav-item');
  const idx=[...items].findIndex(i=>i.getAttribute('onclick')&&i.getAttribute('onclick').includes("'"+page+"'"));
  if(idx>=0) items[idx].classList.add('active');

  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById('page-'+page).classList.add('active');

  const titles={dashboard:'Dashboard',students:'Students',attendance:'Attendance',marks:'Marks & Grades',notes:'Notes'};
  document.getElementById('pageTitle').textContent=titles[page]||page;

  if(page==='dashboard')  renderDashboard();
  if(page==='students')   renderStudents();
  if(page==='attendance') renderAttendance();
  if(page==='marks')      renderMarks();
  if(page==='notes')      renderNotes();
}

// ════════════════════════════════════════════
//  DASHBOARD
// ════════════════════════════════════════════
function renderDashboard(){
  document.getElementById('statStudents').textContent=students.length;
  document.getElementById('statNotes').textContent=notes.length;

  const today=new Date().toISOString().split('T')[0];
  const todayAtt=attendance[today]||{};
  const present=Object.values(todayAtt).filter(a=>a.status==='P').length;
  const pct=students.length?Math.round(present/students.length*100):0;
  document.getElementById('statPresent').textContent=pct+'%';

  const allMarks=students.map(s=>{
    const m=marks[s.id]||{};
    const vals=Object.values(m);
    return vals.length?vals.reduce((a,b)=>a+b,0)/vals.length:0;
  });
  const avg=allMarks.length?Math.round(allMarks.reduce((a,b)=>a+b,0)/allMarks.length):0;
  document.getElementById('statAvgMark').textContent=avg;

  // Recent students
  const rs=document.getElementById('recentStudents');
  rs.innerHTML=students.slice(-5).reverse().map(s=>`
    <div style="display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--border)">
      <div class="avatar" style="width:36px;height:36px;font-size:0.85rem">${s.firstName[0]}</div>
      <div><div style="font-weight:600;font-size:0.9rem">${s.firstName} ${s.lastName}</div><div style="font-size:0.78rem;color:var(--text-muted)">${s.class} · Roll ${s.rollNo}</div></div>
    </div>`).join('');

  // Attendance overview
  const ao=document.getElementById('attendanceOverview');
  ao.innerHTML=students.slice(0,6).map(s=>{
    const records=Object.values(attendance).map(d=>d[s.id]).filter(Boolean);
    const p=records.filter(r=>r.status==='P').length;
    const total=records.length||1;
    const pct2=Math.round(p/total*100);
    const color=pct2>=75?'var(--success)':pct2>=50?'var(--warning)':'var(--danger)';
    return `<div style="display:flex;align-items:center;gap:12px;padding:8px 0;border-bottom:1px solid var(--border)">
      <div style="flex:1;font-size:0.88rem">${s.firstName} ${s.lastName}</div>
      <div class="progress-bar-wrap"><div class="progress-bar" style="width:${pct2}%;background:${color}"></div></div>
      <div style="font-size:0.8rem;color:${color};font-weight:600;width:38px;text-align:right">${pct2}%</div>
    </div>`;
  }).join('');
}

// ════════════════════════════════════════════
//  STUDENTS
// ════════════════════════════════════════════
function renderStudents(){
  const q=document.getElementById('studentSearch').value.toLowerCase();
  const filtered=students.filter(s=>(s.firstName+' '+s.lastName).toLowerCase().includes(q)||s.rollNo.includes(q)||s.class.toLowerCase().includes(q));
  const tbody=document.getElementById('studentTableBody');
  if(!filtered.length){ tbody.innerHTML=`<tr><td colspan="8"><div class="empty-state"><div class="icon">👤</div><p>No students found</p></div></td></tr>`; return; }
  tbody.innerHTML=filtered.map((s,i)=>{
    const records=Object.values(attendance).map(d=>d[s.id]).filter(Boolean);
    const p=records.filter(r=>r.status==='P').length;
    const pct=records.length?Math.round(p/records.length*100):0;
    const attColor=pct>=75?'chip-success':pct>=50?'chip-warning':'chip-danger';
    const m=marks[s.id]||{};
    const vals=Object.values(m);
    const avg=vals.length?Math.round(vals.reduce((a,b)=>a+b,0)/vals.length):0;
    const canEdit=currentUser.role==='admin'||currentUser.role==='teacher';
    return `<tr>
      <td>${i+1}</td>
      <td><div style="display:flex;align-items:center;gap:10px"><div class="avatar" style="width:32px;height:32px;font-size:0.8rem">${s.firstName[0]}</div><div><div style="font-weight:600">${s.firstName} ${s.lastName}</div><div style="font-size:0.75rem;color:var(--text-muted)">${s.email}</div></div></div></td>
      <td><span class="badge badge-blue">${s.class}</span></td>
      <td>${s.rollNo}</td>
      <td style="color:var(--text-muted);font-size:0.85rem">${s.email}</td>
      <td><span class="chip ${attColor}">${pct}%</span></td>
      <td><span style="font-weight:700">${avg}</span>/100</td>
      <td>${canEdit?`<div style="display:flex;gap:6px"><button class="btn btn-secondary btn-sm" onclick="editStudent(${s.id})">✏️ Edit</button><button class="btn btn-danger btn-sm" onclick="deleteStudent(${s.id})">🗑️</button></div>`:'—'}</td>
    </tr>`;
  }).join('');
}

function openAddStudent(){ editingStudentId=null; document.getElementById('studentModalTitle').textContent='Add Student'; ['sFirstName','sLastName','sRollNo','sEmail','sPhone'].forEach(id=>document.getElementById(id).value=''); document.getElementById('studentModal').classList.add('open'); }

function editStudent(id){
  const s=students.find(x=>x.id===id); if(!s) return;
  editingStudentId=id;
  document.getElementById('studentModalTitle').textContent='Edit Student';
  document.getElementById('sFirstName').value=s.firstName;
  document.getElementById('sLastName').value=s.lastName;
  document.getElementById('sRollNo').value=s.rollNo;
  document.getElementById('sClass').value=s.class;
  document.getElementById('sEmail').value=s.email;
  document.getElementById('sPhone').value=s.phone;
  document.getElementById('studentModal').classList.add('open');
}

function saveStudent(){
  const data={ firstName:document.getElementById('sFirstName').value.trim(), lastName:document.getElementById('sLastName').value.trim(), rollNo:document.getElementById('sRollNo').value.trim(), class:document.getElementById('sClass').value, email:document.getElementById('sEmail').value.trim(), phone:document.getElementById('sPhone').value.trim() };
  if(!data.firstName||!data.lastName||!data.rollNo){ alert('Please fill required fields.'); return; }
  if(editingStudentId){
    const idx=students.findIndex(s=>s.id===editingStudentId);
    students[idx]={...students[idx],...data};
  } else {
    students.push({id:nextStudentId++,...data});
    marks[nextStudentId-1]={ Mathematics:0, Science:0, English:0, History:0, Computer:0 };
  }
  closeModal('studentModal'); renderStudents();
}

function deleteStudent(id){ if(confirm('Delete this student?')){ students=students.filter(s=>s.id!==id); renderStudents(); } }

// ════════════════════════════════════════════
//  ATTENDANCE
// ════════════════════════════════════════════
function renderAttendance(){
  const date=document.getElementById('attDate').value;
  const cls=document.getElementById('attClass').value;
  if(!attendance[date]) attendance[date]={};
  const filtered=cls?students.filter(s=>s.class===cls):students;
  const tbody=document.getElementById('attTableBody');
  if(!filtered.length){ tbody.innerHTML=`<tr><td colspan="5"><div class="empty-state"><div class="icon">📋</div><p>No students for this filter</p></div></td></tr>`; return; }
  tbody.innerHTML=filtered.map(s=>{
    const rec=attendance[date][s.id]||{status:'',remark:''};
    const isPresent=rec.status==='P'; const isAbsent=rec.status==='A';
    return `<tr>
      <td><span style="font-weight:600">${s.rollNo}</span></td>
      <td><div style="display:flex;align-items:center;gap:8px"><div class="avatar" style="width:30px;height:30px;font-size:0.78rem">${s.firstName[0]}</div>${s.firstName} ${s.lastName}</div></td>
      <td><span class="badge badge-blue">${s.class}</span></td>
      <td>
        <div class="attendance-cell">
          <button class="att-btn present ${isPresent?'active-present':''}" id="p-${s.id}" onclick="markAtt(${s.id},'P')">✓ Present</button>
          <button class="att-btn absent ${isAbsent?'active-absent':''}"  id="a-${s.id}" onclick="markAtt(${s.id},'A')">✗ Absent</button>
        </div>
      </td>
      <td><input type="text" id="rem-${s.id}" value="${rec.remark||''}" placeholder="Optional remark…" style="padding:6px 10px;border-radius:6px;border:1px solid var(--border);background:var(--surface);color:var(--text);font-family:DM Sans,sans-serif;font-size:0.85rem;width:180px;outline:none;"></td>
    </tr>`;
  }).join('');
  renderAttHistory();
}

function markAtt(id, status){
  const date=document.getElementById('attDate').value;
  if(!attendance[date]) attendance[date]={};
  const existing=attendance[date][id]||{};
  attendance[date][id]={...existing, status};
  const pb=document.getElementById('p-'+id); const ab=document.getElementById('a-'+id);
  pb.className='att-btn present'+(status==='P'?' active-present':'');
  ab.className='att-btn absent'+(status==='A'?' active-absent':'');
}

function saveAttendance(){
  const date=document.getElementById('attDate').value;
  if(!attendance[date]) attendance[date]={};
  const cls=document.getElementById('attClass').value;
  const filtered=cls?students.filter(s=>s.class===cls):students;
  filtered.forEach(s=>{
    const rem=document.getElementById('rem-'+s.id);
    if(rem){ if(!attendance[date][s.id]) attendance[date][s.id]={status:'',remark:''}; attendance[date][s.id].remark=rem.value; }
  });
  alert('✅ Attendance saved for '+date+'!'); renderAttHistory();
}

function renderAttHistory(){
  const dates=Object.keys(attendance).sort((a,b)=>b.localeCompare(a)).slice(0,5);
  const el=document.getElementById('attHistory');
  if(!dates.length){ el.innerHTML='<div class="empty-state"><div class="icon">📅</div><p>No attendance records yet</p></div>'; return; }
  el.innerHTML=`<div class="table-wrap"><table><thead><tr><th>Date</th><th>Present</th><th>Absent</th><th>Rate</th></tr></thead><tbody>${
    dates.map(d=>{
      const recs=attendance[d];
      const p=Object.values(recs).filter(r=>r.status==='P').length;
      const a=Object.values(recs).filter(r=>r.status==='A').length;
      const total=p+a||1; const pct=Math.round(p/total*100);
      return `<tr><td>${d}</td><td><span class="chip chip-success">✓ ${p}</span></td><td><span class="chip chip-danger">✗ ${a}</span></td><td><div style="display:flex;align-items:center;gap:10px"><div class="progress-bar-wrap" style="width:80px"><div class="progress-bar" style="width:${pct}%;background:${pct>=75?'var(--success)':pct>=50?'var(--warning)':'var(--danger)'}"></div></div>${pct}%</div></td></tr>`;
    }).join('')
  }</tbody></table></div>`;
}

// ════════════════════════════════════════════
//  MARKS
// ════════════════════════════════════════════
const SUBJECTS=['Mathematics','Science','English','History','Computer'];

function renderMarks(){
  const cls=document.getElementById('marksClass').value;
  const filtered=cls?students.filter(s=>s.class===cls):students;
  const tbody=document.getElementById('marksTableBody');
  if(!filtered.length){ tbody.innerHTML=`<tr><td colspan="9"><div class="empty-state"><div class="icon">📊</div><p>No students found</p></div></td></tr>`; return; }
  tbody.innerHTML=filtered.map(s=>{
    const m=marks[s.id]||{}; const vals=SUBJECTS.map(sub=>m[sub]||0);
    const total=vals.reduce((a,b)=>a+b,0); const avg=Math.round(total/SUBJECTS.length);
    const grade=avg>=90?'A+':avg>=80?'A':avg>=70?'B':avg>=60?'C':avg>=50?'D':'F';
    const gradeColor=avg>=70?'var(--success)':avg>=50?'var(--warning)':'var(--danger)';
    const canEdit=currentUser.role==='admin'||currentUser.role==='teacher';
    return `<tr>
      <td><div style="display:flex;align-items:center;gap:8px"><div class="avatar" style="width:30px;height:30px;font-size:0.78rem">${s.firstName[0]}</div>${s.firstName} ${s.lastName}</div></td>
      <td><span class="badge badge-blue">${s.class}</span></td>
      ${SUBJECTS.map(sub=>`<td>${canEdit?`<input type="number" min="0" max="100" value="${m[sub]||0}" id="m-${s.id}-${sub}" oninput="updateTotalRow(${s.id})">`:`<span style="font-weight:600">${m[sub]||0}</span>`}</td>`).join('')}
      <td id="total-${s.id}" style="font-weight:700">${total}</td>
      <td><span style="font-weight:800;color:${gradeColor};font-family:'Syne',sans-serif">${grade}</span></td>
    </tr>`;
  }).join('');
}

function updateTotalRow(sid){
  const vals=SUBJECTS.map(sub=>{ const el=document.getElementById(`m-${sid}-${sub}`); return el?parseInt(el.value)||0:0; });
  const total=vals.reduce((a,b)=>a+b,0);
  const el=document.getElementById('total-'+sid); if(el) el.textContent=total;
}

function saveMarks(){
  students.forEach(s=>{
    SUBJECTS.forEach(sub=>{
      const el=document.getElementById(`m-${s.id}-${sub}`);
      if(el){ if(!marks[s.id]) marks[s.id]={}; marks[s.id][sub]=parseInt(el.value)||0; }
    });
  });
  alert('✅ Marks saved successfully!'); renderMarks();
}

// ════════════════════════════════════════════
//  NOTES
// ════════════════════════════════════════════
const NOTE_COLORS=['#3b82f6','#10b981','#f59e0b','#ef4444','#8b5cf6'];

function renderNotes(){
  const grid=document.getElementById('notesGrid');
  if(!notes.length){ grid.innerHTML=`<div class="empty-state" style="grid-column:1/-1"><div class="icon">📝</div><p>No notes yet. Create your first note!</p></div>`; return; }
  grid.innerHTML=notes.map(n=>`
    <div class="note-card" onclick="viewNote(${n.id})">
      <div class="note-color" style="background:${n.color}"></div>
      <div style="padding-left:8px">
        <div class="note-title">${n.title}</div>
        <div class="note-body">${n.body}</div>
        <div class="note-meta">
          <span>${n.date}</span>
          <button class="note-delete" onclick="event.stopPropagation();deleteNote(${n.id})">🗑️</button>
        </div>
      </div>
    </div>`).join('');
}

function openAddNote(){ editingNoteId=null; document.getElementById('noteTitle').value=''; document.getElementById('noteBody').value=''; document.getElementById('noteModal').classList.add('open'); }

function saveNote(){
  const title=document.getElementById('noteTitle').value.trim();
  const body=document.getElementById('noteBody').value.trim();
  const color=document.getElementById('noteColor').value;
  if(!title){ alert('Title is required.'); return; }
  const now=new Date().toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'});
  notes.unshift({ id:nextNoteId++, title, body, color, date:now, author:currentUser.name });
  closeModal('noteModal'); renderNotes();
}

function viewNote(id){
  const n=notes.find(x=>x.id===id); if(!n) return;
  document.getElementById('viewNoteTitle').textContent=n.title;
  document.getElementById('viewNoteBody').textContent=n.body;
  document.getElementById('viewNoteMeta').textContent=`By ${n.author} · ${n.date}`;
  document.getElementById('viewNoteModal').classList.add('open');
}

function deleteNote(id){ if(confirm('Delete this note?')){ notes=notes.filter(n=>n.id!==id); renderNotes(); } }

// ════════════════════════════════════════════
//  UTILS
// ════════════════════════════════════════════
function closeModal(id){ document.getElementById(id).classList.remove('open'); }
document.querySelectorAll('.modal-overlay').forEach(m=>m.addEventListener('click',e=>{ if(e.target===m) m.classList.remove('open'); }));
</script>
</body>
</html>
