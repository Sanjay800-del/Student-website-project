        <div class="table-wrap">
          <table class="marks-table">
            <thead><tr><th>Student</th><th>Class</th><th>Math</th><th>Science</th><th>English</th><th>History</th><th>Computer</th><th>Total</th><th>Grade</th></tr></thead>
            <tbody id="marksTableBody"></tbody>
          </table>
        </div>
